---
// Renders a JSON-LD structured-data block. `schema` is any plain object from
// src/lib/seo.ts. Astro leaves application/ld+json scripts untouched.
interface Props { schema: unknown; }
const { schema } = Astro.props;
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
