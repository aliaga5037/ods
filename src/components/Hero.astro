---
import { site } from '../data/site';

// Background hero video (YouTube). Set `videoId` to a YouTube video ID to show a
// video background; leave it '' to show the animated particle-network background
// instead (current default until a real rig video is uploaded).
// Previous placeholder clip: 'Su3Rf5pFQyM'
const videoId = 'Su3Rf5pFQyM';
const videoSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&showinfo=0&modestbranding=1&rel=0&playsinline=1&disablekb=1&iv_load_policy=3`;
---
<section class="relative isolate min-h-[88vh] flex items-center overflow-hidden bg-ink">
  {/* Layering uses a positive z scale, scoped by `isolate` on the section:
      gradient (0) → video (1) → scrim (2) → particles (3) → content (10). */}
  {/* Branded gradient base — always visible, so the hero is never plain black
      even if the video is blocked, slow, or unavailable (Midnight Brass palette). */}
  <div class="absolute inset-0 z-0"
       style="background: radial-gradient(120% 110% at 75% 20%, rgba(22,70,122,0.40), transparent 60%), radial-gradient(90% 90% at 15% 90%, rgba(184,134,59,0.14), transparent 55%), linear-gradient(135deg, #05080d 0%, #0d1c2e 100%);"></div>
  {!videoId && (
    <canvas id="hero-particles" class="absolute inset-0 z-[3] h-full w-full pointer-events-none" aria-hidden="true"></canvas>
  )}
  {videoId && (
    <div class="absolute inset-0 z-[1] overflow-hidden pointer-events-none" aria-hidden="true">
      {/* Iframe is oversized (scale-[1.45]) so YouTube's player chrome — control
          bar, title and play button that flash during load — is pushed outside
          the overflow-hidden container and never shows. */}
      <iframe
        id="hero-video"
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 scale-[1.45] w-[177.78vh] min-w-full h-[56.25vw] min-h-full border-0 opacity-0 transition-opacity duration-700"
        src={videoSrc}
        title="Rig site drilling background"
        allow="autoplay; encrypted-media; picture-in-picture"
        referrerpolicy="strict-origin-when-cross-origin"
        tabindex="-1"></iframe>
      {/* Transparent click/hover shield so no controls can ever be triggered. */}
      <div class="absolute inset-0"></div>
    </div>
  )}
  {/* Directional scrim: dark behind the text (left), clearer on the right so the
      particle network stays visible. */}
  <div class="absolute inset-0 z-[2] bg-gradient-to-r from-ink/85 via-ink/40 to-transparent"></div>
  <div class="absolute inset-0 z-[2] bg-gradient-to-t from-ink/45 to-transparent"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 w-full">
    <div class="max-w-2xl">
      <div class="hero-rise text-xs tracking-[0.3em] uppercase text-brass font-semibold mb-5" style="animation-delay:.05s">Independent Drilling Fluids Consultancy</div>
      <h1 class="hero-rise text-4xl md:text-6xl font-bold leading-[1.05]" style="animation-delay:.15s">Wellsite Engineering,<br />Proven in the Field.</h1>
      <p class="hero-rise text-text-light mt-6 text-lg max-w-xl" style="animation-delay:.3s">{site.subhead}</p>
      <div class="hero-rise flex flex-wrap gap-4 mt-9" style="animation-delay:.45s">
        <a href="/services" class="bg-brass text-ink font-semibold px-6 py-3 rounded-md hover:bg-brass-soft transition-colors">Our Services</a>
        <a href="/contact" class="border border-brass text-brass font-semibold px-6 py-3 rounded-md hover:bg-brass/10 transition-colors">Talk to an Engineer</a>
      </div>
    </div>
  </div>

  <script>
    // Keep the YouTube iframe hidden until its loading chrome (center play/pause
    // overlay, control bar) has cleared, then fade it in over the gradient.
    const video = document.getElementById('hero-video') as HTMLIFrameElement | null;
    if (video) {
      const reveal = () => { video.style.opacity = '1'; };
      video.addEventListener('load', () => setTimeout(reveal, 1800));
      setTimeout(reveal, 4000); // fallback if the load event timing is missed
    }
  </script>

  <script>
    const canvas = document.getElementById('hero-particles') as HTMLCanvasElement | null;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (canvas && !reduce) {
      const ctx = canvas.getContext('2d')!;
      let w = 0, h = 0, raf = 0, running = false;
      type P = { x: number; y: number; vx: number; vy: number };
      let pts: P[] = [];

      const resize = () => {
        const r = canvas.getBoundingClientRect();
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        w = r.width; h = r.height;
        canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const count = Math.min(70, Math.round((w * h) / 22000));
        pts = Array.from({ length: count }, () => ({
          x: Math.random() * w, y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.35, vy: (Math.random() - 0.5) * 0.35,
        }));
      };

      const frame = () => {
        ctx.clearRect(0, 0, w, h);
        for (const p of pts) {
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0 || p.x > w) p.vx *= -1;
          if (p.y < 0 || p.y > h) p.vy *= -1;
        }
        for (let i = 0; i < pts.length; i++) {
          for (let j = i + 1; j < pts.length; j++) {
            const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
            const dist = Math.hypot(dx, dy);
            if (dist < 130) {
              ctx.strokeStyle = `rgba(184,134,59,${0.18 * (1 - dist / 130)})`;
              ctx.beginPath(); ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y); ctx.stroke();
            }
          }
        }
        ctx.fillStyle = 'rgba(216,184,120,0.55)';
        for (const p of pts) { ctx.beginPath(); ctx.arc(p.x, p.y, 1.6, 0, Math.PI * 2); ctx.fill(); }
        raf = requestAnimationFrame(frame);
      };

      const start = () => { if (!running) { running = true; raf = requestAnimationFrame(frame); } };
      const stop = () => { running = false; cancelAnimationFrame(raf); };

      resize();
      window.addEventListener('resize', resize);
      document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));
      const io = new IntersectionObserver((es) => es.forEach((e) => (e.isIntersecting ? start() : stop())), { threshold: 0 });
      io.observe(canvas);
    }
  </script>
</section>
